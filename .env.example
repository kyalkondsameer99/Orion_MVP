# =============================================================================
# Orion MVP — copy to `.env` in the repo root (Docker Compose & local dev).
# The backend also reads `backend/.env` if present (later file wins on duplicates).
# =============================================================================

# --- General ---
# Maps to ENVIRONMENT; use `development` to normalize to `dev` in the API.
ENVIRONMENT=dev
# APP_ENV=development
DEBUG=true
SECRET_KEY=change-me-in-production-use-long-random-string

# --- MVP safety (kill switch) ---
TRADING_ENABLED=true
MAX_OPEN_POSITIONS=20

# --- Ports (host → container) ---
POSTGRES_PORT=5432
REDIS_PORT=6379
BACKEND_PORT=8000
FRONTEND_PORT=3000

# --- PostgreSQL ---
POSTGRES_USER=orion
POSTGRES_PASSWORD=orion
POSTGRES_DB=orion

# Local backend on host (optional explicit URL):
# DATABASE_URL=postgresql+psycopg2://orion:orion@localhost:5432/orion

# --- Redis (RQ workers) ---
REDIS_URL=redis://localhost:6379/0

# --- Alpaca paper trading ---
# Use either pair (ID/SECRET) or the common aliases on the right:
# ALPACA_API_KEY_ID=...
# ALPACA_API_SECRET_KEY=...
# ALPACA_API_KEY=...
# ALPACA_API_SECRET=...
# ALPACA_PAPER_BASE_URL=https://paper-api.alpaca.markets
# (alias) ALPACA_BASE_URL=https://paper-api.alpaca.markets

# --- Optional integrations (when adapters are wired) ---
# NEWS_API_KEY=
# OPENAI_API_KEY=

# --- Frontend (browser) ---
# NEXT_PUBLIC_DEFAULT_USER_ID=
